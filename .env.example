# Xavi Pi Agent

PORT=3000

# Shared inbound API auth for /v1/chat, /webhooks/*, and local mock-task routes.
COWORKERS_API_KEY=
COWORKERS_REQUIRE_AUTH=true
COWORKERS_RATE_LIMIT_WINDOW_MS=60000
COWORKERS_RATE_LIMIT_MAX_REQUESTS=60

# Pi/OpenRouter model calls
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_COMPLETION_TOKENS=1200
OPENROUTER_TEMPERATURE=0.4
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Xavi Pi Agent

# Local testing only. Real deployments should leave this false/unset.
PI_AGENT_MOCK_RESPONSES=false

# Sokosumi coworker worker
SOKOSUMI_API_URL=https://api.preprod.sokosumi.com
SOKOSUMI_COWORKER_API_KEY=
SOKOSUMI_TASK_POLLER_ENABLED=false
SOKOSUMI_TASK_POLL_INTERVAL_MS=15000
SOKOSUMI_TASK_POLL_LIMIT=20
SOKOSUMI_TASK_POLL_MAX_PAGES=10

# Local Sokosumi smoke-test endpoint. Disabled by default.
SOKOSUMI_MOCK_ENDPOINT_ENABLED=false
